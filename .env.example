# Yahoo Fantasy API credentials (see yahoo-fantasy-api package for setup)
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_REDIRECT_URI=https://localhost:3000/auth/callback
YAHOO_MLB_LEAGUE_ID=

# Anthropic API key for AI narration (claude CLI must be installed)
ANTHROPIC_API_KEY=

# GitHub Pages deploy target (e.g., "your-user/your-recap-site")
DEPLOY_REPO=

# Optional: Cloudflare Worker URL for trade rumours feature
# RUMOURS_API_URL=https://trade-rumours.your-subdomain.workers.dev/api/rumours

# Optional: override league name for the site header (auto-detected from Yahoo data)
# LEAGUE_NAME=My Fantasy League

# Optional: league-specific settings (defaults shown)
# FAAB_BUDGET=200
# MIN_IP=30
